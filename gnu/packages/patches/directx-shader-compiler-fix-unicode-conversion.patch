From 6173c2a0732f4af2cd5d128729f62780c8ead70d Mon Sep 17 00:00:00 2001
From: Tex Riddell <texr@microsoft.com>
Date: Tue, 2 Sep 2025 14:13:25 -0700
Subject: [PATCH 3/3] Remove OOB index assert, catch more invalid
 uses/overflows

---
 lib/DxcSupport/Unicode.cpp | 33 +++++++++++++++++++++++++--------
 1 file changed, 25 insertions(+), 8 deletions(-)

diff --git a/lib/DxcSupport/Unicode.cpp b/lib/DxcSupport/Unicode.cpp
index f5dd539e94..cb3a98ae4a 100644
--- a/lib/DxcSupport/Unicode.cpp
+++ b/lib/DxcSupport/Unicode.cpp
@@ -28,7 +28,9 @@ int MultiByteToWideChar(uint32_t /*CodePage*/, uint32_t /*dwFlags*/,
                         const char *lpMultiByteStr, int cbMultiByte,
                         wchar_t *lpWideCharStr, int cchWideChar) {
 
-  if (cbMultiByte == 0) {
+  // Check for invalid sizes or potential overflow.
+  if (cbMultiByte == 0 || cbMultiByte < -1 || cbMultiByte > (INT32_MAX - 1) ||
+      cchWideChar < 0 || cchWideChar > (INT32_MAX - 1)) {
     SetLastError(ERROR_INVALID_PARAMETER);
