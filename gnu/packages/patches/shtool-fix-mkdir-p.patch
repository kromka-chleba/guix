Retrieved-from: https://salsa.debian.org/debian/shtool/-/raw/debian/master/debian/patches/40_fix-mkdir-p.patch?ref_type=heads
Upstream-status: https://savannah.gnu.org/support/index.php?111344

Description: fix the mkdir -p implementation, make parallel executions fail.
Author: Raphael Geissert <geissert@debian.org>
Last-Update: 2010-07-25
Index: shtool-2.0.8/sh.mkdir
===================================================================
--- shtool-2.0.8.orig/sh.mkdir
+++ shtool-2.0.8/sh.mkdir
@@ -86,7 +86,11 @@ for p in ${1+"$@"}; do
                 if [ ".$opt_t" = .yes ]; then
                     echo "mkdir $pathcomp" 1>&2
                 fi
-                mkdir $pathcomp || errstatus=$?
+                mkdir $pathcomp || {
+                    _errstatus=$?
+                    [ -d "$pathcomp" ] || errstatus=${_errstatus}
+                    unset _errstatus
+                }
                 if [ ".$opt_o" != . ]; then
                     if [ ".$opt_t" = .yes ]; then
                         echo "chown $opt_o $pathcomp" 1>&2
