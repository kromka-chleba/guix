Subject: [PATCH] Ensure deterministic embed order.

Sort table of embedded scripts by their name.
---
 scripts/embed.lua | 4 ++++
 1 file changed, 4 insertions(+)

diff --git a/scripts/embed.lua b/scripts/embed.lua
index 0d650c4268..98e621bde1 100644
--- a/scripts/embed.lua
+++ b/scripts/embed.lua
@@ -155,6 +155,10 @@
 
 	addScript(contentTable, "_modules.lua", "src/_modules.lua", "return {" .. table.implode(modules, '"', '"', ', ') .. "}")
 
+-- Sort scripts to ensure deterministic order
+
+	table.sort(contentTable, function(a, b) return a.name < b.name end)
+
 -- Embed the actual script contents
 
 	print("Embedding...")
